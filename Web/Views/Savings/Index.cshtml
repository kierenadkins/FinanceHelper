@using FinanceHelper.Web.Models.Saving
@model SavingsModel

@{
    ViewData["Title"] = "Savings Dashboard";
}

<div class="container-lg py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h3 fw-bold mb-2">Savings Dashboard</h1>
            <p class="text-muted mb-0">Track progression and manage your saving accounts</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Add Account
        </a>
    </div>

    @if (Model?.Savings != null && Model.Savings.Any())
    {
        <!-- Summary KPI Cards -->
        <div class="row g-3 mb-5">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-gradient-success text-white">
                    <div class="card-body">
                        <h6 class="card-title mb-2 text-white-50">Total Balance</h6>
                        <h3 class="fw-bold mb-0">£@Model.TotalBalance.ToString("F2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-gradient-info text-white">
                    <div class="card-body">
                        <h6 class="card-title mb-2 text-white-50">Total Interest</h6>
                        <h3 class="fw-bold text-success mb-0">+£@Model.TotalInterestEarned.ToString("F2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-gradient-warning text-white">
                    <div class="card-body">
                        <h6 class="card-title mb-2 text-white-50">Total With Interest</h6>
                        <h3 class="fw-bold mb-0">£@Model.TotalWithInterest.ToString("F2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-gradient-primary text-white">
                    <div class="card-body">
                        <h6 class="card-title mb-2 text-white-50">Accounts</h6>
                        <h3 class="fw-bold mb-0">@Model.Savings.Count</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Individual Account Progression Cards -->
        <div class="row g-4">
            @foreach (var account in Model.Savings)
            {
                var recentTransactions = account.ProgressionHistory.TakeLast(10).ToList();
                var projectedInterest = account.GetProjectedInterest(12);

                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <!-- Header -->
                        <div class="card-header bg-light border-0">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="fw-bold mb-1">@account.Name</h5>
                                    <small class="text-muted">@account.Provider • @account.AccountType</small>
                                </div>
                                <a asp-action="Edit" asp-route-id="@account.Id" class="btn btn-sm btn-outline-primary rounded-pill">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Stats Row -->
                        <div class="card-body border-bottom">
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="mb-3">
                                        <small class="text-muted d-block mb-1">Current Balance</small>
                                        <h6 class="fw-bold">£@account.Balance.ToString("F2")</h6>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block mb-1">Interest Rate</small>
                                        <h6 class="fw-bold">@account.InterestRate%</h6>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="mb-3">
                                        <small class="text-muted d-block mb-1">Interest Earned</small>
                                        <h6 class="fw-bold text-success">+£@account.TotalInterestEarned.ToString("F2")</h6>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block mb-1">Type</small>
                                        <h6 class="fw-bold">
                                            <span class="badge bg-info">@account.InterestType</span>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Projection -->
                        @if (!string.IsNullOrEmpty(account.InterestType) && account.InterestType != "None" && account.InterestRate > 0)
                        {
                            <div class="card-body border-bottom bg-light bg-opacity-50">
                                <small class="text-muted d-block mb-2">
                                    <i class="bi bi-graph-up me-1"></i>Projected Interest (12 months)
                                </small>
                                <div class="progress" style="height: 20px;">
                                    @{
                                        var projectedPercent = account.TotalInterestEarned > 0 
                                            ? Math.Min((projectedInterest / account.Balance * 100), 100) 
                                            : 0;
                                    }
                                    <div class="progress-bar bg-success" style="width: @projectedPercent%"></div>
                                </div>
                                <small class="text-muted d-block mt-2">+£@projectedInterest.ToString("F2")</small>
                            </div>
                        }

                        <!-- Recent Transactions -->
                        <div class="card-body">
                            <h6 class="fw-bold mb-3">Recent Activity</h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-borderless mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Date</th>
                                            <th>Type</th>
                                            <th class="text-end">Amount</th>
                                            <th class="text-end">Balance</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var trans in recentTransactions)
                                        {
                                            var typeClass = trans.Type switch
                                            {
                                                "Deposit" => "bg-success bg-opacity-10 text-success",
                                                "Interest" => "bg-info bg-opacity-10 text-info",
                                                "Withdrawal" => "bg-danger bg-opacity-10 text-danger",
                                                _ => "bg-secondary bg-opacity-10"
                                            };

                                            var amountClass = trans.Type == "Withdrawal" ? "text-danger" : "text-success";

                                            <tr>
                                                <td>
                                                    <small>@trans.Date.ToString("dd MMM")</small>
                                                </td>
                                                <td>
                                                    <small>
                                                        <span class="badge @typeClass rounded-pill">
                                                            @if (trans.Type == "Deposit")
                                                            {
                                                                <i class="bi bi-arrow-down me-1"></i>
                                                            }
                                                            else if (trans.Type == "Interest")
                                                            {
                                                                <i class="bi bi-star-fill me-1"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-arrow-up me-1"></i>
                                                            }
                                                            @trans.Type
                                                        </span>
                                                    </small>
                                                </td>
                                                <td class="text-end">
                                                    <small class="fw-semibold @amountClass">
                                                        @if (trans.Type == "Withdrawal")
                                                        {
                                                            <text>-£@trans.Amount.ToString("F2")</text>
                                                        }
                                                        else
                                                        {
                                                            <text>+£@trans.Amount.ToString("F2")</text>
                                                        }
                                                    </small>
                                                </td>
                                                <td class="text-end">
                                                    <small class="fw-bold">£@trans.RunningBalance.ToString("F2")</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="card-footer bg-light border-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    Last interest: @account.LastInterestDate.ToString("dd MMM yyyy")
                                </small>
                                <a asp-action="Edit" asp-route-id="@account.Id" class="btn btn-sm btn-outline-secondary rounded-pill">
                                    View Full History
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm rounded-3 p-5 text-center">
            <div class="mb-4">
                <i class="bi bi-inbox" style="font-size: 4rem; color: #6c757d;"></i>
            </div>
            <h4 class="fw-bold mb-2">No Saving Accounts Yet</h4>
            <p class="text-muted mb-4">Get started by adding your first saving account to track your money growth and earnings.</p>
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill">
                <i class="bi bi-plus-circle me-2"></i>Create Your First Account
            </a>
        </div>
    }

</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this account?')) {
                console.log('Deleting account:', id);
            }
        }
    </script>
}

<style>
    .bg-gradient-success {
        background: linear-gradient(135deg, #198754 0%, #20c997 100%) !important;
    }

    .bg-gradient-info {
        background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%) !important;
    }

    .bg-gradient-warning {
        background: linear-gradient(135deg, #ffc107 0%, #ff6b6b 100%) !important;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #0d6efd 0%, #6f42c1 100%) !important;
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.175) !important;
    }

    .table-sm tbody tr:hover {
        background-color: rgba(0, 0, 0, 0.02);
    }
</style>
