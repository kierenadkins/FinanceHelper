@using FinanceHelper.Application.Interfaces
@using FinanceHelper.Application.Services.Session
@inject ISessionManagerService SessionManager

@{
    var userSession = SessionManager.Get<int>("CurrentUser");
    var isLoggedIn = userSession > 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceBuddy</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary shadow-sm sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold fs-5" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-wallet2 me-2"></i>FinanceBuddy
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <!-- Left side nav -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-fill me-1"></i>Home
                            </a>
                        </li>
                        @if (isLoggedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Finance" ? "active" : "")"
                                   asp-area="" asp-controller="Finance" asp-action="Index">
                                    <i class="bi bi-graph-up me-1"></i>Finance
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Savings" ? "active" : "")"
                                   asp-area="" asp-controller="Savings" asp-action="Index">
                                    <i class="bi bi-piggy-bank me-1"></i>Savings
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (isLoggedIn)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="accountDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i>Account
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="accountDropdown">
                                    <li class="dropdown-header">Account</li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm" asp-controller="Auth" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top bg-light text-muted py-3 mt-auto">
        <div class="container-fluid">
            <div class="row g-3 text-center text-sm-start">
                <div class="col-sm-4 col-12">
                    <h6 class="fw-bold text-dark mb-1">FinanceBuddy</h6>
                    <p class="small mb-0">Manage your finances with ease.</p>
                </div>
                <div class="col-sm-4 col-12">
                    <h6 class="fw-bold text-dark mb-1">Links</h6>
                    <ul class="list-unstyled small">
                        <li><a href="@Url.Action("Index", "Home")" class="text-muted text-decoration-none">Home</a></li>
                        <li><a href="@Url.Action("Privacy", "Home")" class="text-muted text-decoration-none">Privacy</a></li>
                    </ul>
                </div>
                <div class="col-sm-4 col-12">
                    <h6 class="fw-bold text-dark mb-1">Follow</h6>
                    <div class="d-flex gap-2 justify-content-center justify-content-sm-start">
                        <a href="#" class="text-muted text-decoration-none"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="text-muted text-decoration-none"><i class="bi bi-github"></i></a>
                        <a href="#" class="text-muted text-decoration-none"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-2">
            <div class="text-center">
                <small>&copy; 2025 FinanceBuddy. All rights reserved.</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>