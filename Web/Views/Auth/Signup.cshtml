@using FinanceHelper.Web.Models.Auth
@model SignupViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: calc(100vh - 180px);">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-5">
                    <div class="text-center mb-5">
                        <div class="mb-3">
                            <i class="bi bi-wallet2 text-primary" style="font-size: 3rem;"></i>
                        </div>
                        <h2 class="fw-bold text-primary mb-2">Get Started</h2>
                        <p class="text-muted">Create your FinanceBuddy account in seconds</p>
                    </div>

                    @if (Model?.Errors != null && Model.Errors.Errors.Any())
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle me-2"></i>
                            <strong>Please fix the following errors:</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var error in Model.Errors.Errors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Signup" method="post" novalidate class="needs-validation">
                        @Html.AntiForgeryToken()

                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label asp-for="FirstName" class="form-label fw-semibold">First Name</label>
                                <input asp-for="FirstName" 
                                       class="form-control form-control-lg" 
                                       placeholder="John"
                                       required />
                                <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-6">
                                <label asp-for="LastName" class="form-label fw-semibold">Last Name</label>
                                <input asp-for="LastName" 
                                       class="form-control form-control-lg" 
                                       placeholder="Doe"
                                       required />
                                <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EmailAddress" class="form-label fw-semibold">Email Address</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>
                                <input asp-for="EmailAddress" 
                                       type="email"
                                       class="form-control form-control-lg" 
                                       placeholder="you@example.com"
                                       required />
                            </div>
                            <span asp-validation-for="EmailAddress" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                <input asp-for="Password" 
                                       type="password" 
                                       class="form-control form-control-lg" 
                                       placeholder="Create password"
                                       required />
                            </div>
                            <small class="text-muted d-block mt-1">Must be at least 8 characters</small>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-lock-check text-muted"></i>
                                </span>
                                <input asp-for="ConfirmPassword" 
                                       type="password" 
                                       class="form-control form-control-lg" 
                                       placeholder="Confirm password"
                                       required />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 btn-lg fw-semibold rounded-3 mb-3">
                            <i class="bi bi-person-plus me-2"></i>Create Account
                        </button>
                    </form>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="text-muted mb-0">
                            Already have an account?
                            <a asp-controller="Auth" asp-action="Login" class="text-primary fw-semibold text-decoration-none">
                                Sign in here
                            </a>
                        </p>
                    </div>

                    <div class="mt-4 pt-3 text-center">
                        <small class="text-muted">
                            <i class="bi bi-shield-check text-success me-1"></i>
                            By signing up, you agree to our Terms of Service
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}