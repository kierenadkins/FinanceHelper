@using FinanceHelper.Web.Models.Finance
@model FinanceModel

@{
    ViewData["Title"] = "Finance Dashboard";
}

<div class="container-xxl py-4">

    @* ===============================
       NO SALARY → FULL PAGE INPUT
       =============================== *@
    @if (Model?.Salary == null)
    {
        @await Html.PartialAsync("_salaryInput", new SalaryInputModel())
    }
    else
    {
        @* ===============================
           HEADER + EDIT BUTTON
           =============================== *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold mb-0">Finance Dashboard</h3>
                <small class="text-muted">Overview of your income, taxes, and spending</small>
            </div>

            <button class="btn btn-sm btn-outline-primary rounded-pill"
                    data-bs-toggle="modal"
                    data-bs-target="#editSalaryModal">
                <i class="bi bi-pencil"></i> Edit salary
            </button>
        </div>

        @* ===============================
           KPI CARDS
           =============================== *@
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="kpi-card bg-success p-3">
                    <div>
                        <h6 class="mb-1">Net Income</h6>
                        <h4 class="fw-bold mb-0">£@Model.Salary.NetSalary</h4>
                        <small>£@Model.Salary.SalaryMonthly.NetSalary / month</small>
                    </div>
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
            </div>

            <div class="col-md-4">
                <div class="kpi-card bg-warning p-3">
                    <div>
                        <h6 class="mb-1">Outgoings</h6>
                        <h4 class="fw-bold mb-0">£@Model.YearlyTotalOutGoings</h4>
                        <small>£@Model.MonthlyOutGoings / month</small>
                    </div>
                    <i class="bi bi-credit-card"></i>
                </div>
            </div>

            <div class="col-md-4">
                <div class="kpi-card bg-primary p-3">
                    <div>
                        <h6 class="mb-1">Left Over</h6>
                        <h4 class="fw-bold mb-0">£@Model.YearlyLeftOver</h4>
                        <small>£@Model.MonthlyLeftOver / month</small>
                    </div>
                    <i class="bi bi-piggy-bank"></i>
                </div>
            </div>
        </div>

        @* ===============================
           SALARY BREAKDOWN
           =============================== *@
        <div class="card border-0 shadow-sm rounded-3 mb-4 overflow-hidden">
            <div class="card-header bg-body-secondary px-3 py-2">
                <h6 class="mb-0 fw-semibold">Salary Breakdown</h6>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th>Item</th>
                            <th>Yearly</th>
                            <th>Monthly</th>
                            <th>Weekly</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Gross Salary</td>
                            <td>£@Model.Salary.GrossSalary</td>
                            <td>£@Model.Salary.SalaryMonthly.GrossSalary</td>
                            <td>£@Model.Salary.SalaryWeekly.GrossSalary</td>
                        </tr>
                        <tr class="fw-semibold">
                            <td>Net Salary</td>
                            <td>£@Model.Salary.NetSalary</td>
                            <td>£@Model.Salary.SalaryMonthly.NetSalary</td>
                            <td>£@Model.Salary.SalaryWeekly.NetSalary</td>
                        </tr>
                        <tr>
                            <td>Tax</td>
                            <td>£@Model.Salary.Tax</td>
                            <td>£@Model.Salary.SalaryMonthly.Tax</td>
                            <td>£@Model.Salary.SalaryWeekly.Tax</td>
                        </tr>
                        <tr>
                            <td>National Insurance</td>
                            <td>£@Model.Salary.NationalInsurance</td>
                            <td>£@Model.Salary.SalaryMonthly.NationalInsurance</td>
                            <td>£@Model.Salary.SalaryWeekly.NationalInsurance</td>
                        </tr>
                        <tr>
                            <td>Pension (@Model.Salary.PensionPercentage%)</td>
                            <td>£@Model.Salary.PensionContribution</td>
                            <td>£@Model.Salary.SalaryMonthly.PensionContribution</td>
                            <td>£@Model.Salary.SalaryWeekly.PensionContribution</td>
                        </tr>

                        @if (Model.Salary.HasStudentLoan)
                        {
                            <tr>
                                <td>Student Loan (@Model.Salary.StudentPlanType)</td>
                                <td>£@Model.Salary.StudentLoan</td>
                                <td>£@Model.Salary.SalaryMonthly.StudentLoan</td>
                                <td>£@Model.Salary.SalaryWeekly.StudentLoan</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* ===============================
           SPENDING CATEGORIES
           =============================== *@
        <div class="mb-3">
            <h5 class="fw-semibold mb-3">Spending Categories</h5>

            <div class="d-flex flex-row flex-nowrap overflow-auto gap-3">
                @foreach (var cat in Model.Category)
                {
                    <div class="col-12 col-sm-6 col-lg-4 flex-shrink-0">
                        <div class="card border-0 shadow-sm rounded-3 p-3 category-tile">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-semibold mb-0">@cat.Name</h6>
                                <span class="badge bg-success-subtle text-success">Yearly</span>
                            </div>
                            <h5 class="fw-bold mb-2">£@cat.YearlyCost</h5>
                            <div class="small d-flex justify-content-between">
                                <span class="text-muted">Monthly</span>
                                <span>£@cat.MonthlyCost</span>
                            </div>
                            <div class="small d-flex justify-content-between">
                                <span class="text-muted">Weekly</span>
                                <span>£@cat.WeeklyCost</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @await Html.PartialAsync("_CategoryPartial", Model.Category)
    }
</div>

@* ===============================
   EDIT SALARY MODAL
   =============================== *@
@if (Model?.Salary != null)
{
    <div class="modal fade" id="editSalaryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content border-0 rounded-4 shadow">
                <div class="modal-body p-0">
                    @await Html.PartialAsync("_salaryInput",
                    new SalaryInputModel
                    {
                        SalaryId = Model.Salary.Id,
                        GrossSalary = Model.Salary.GrossSalary
                    })
            </div>
        </div>
    </div>
</div>
}


<style>
    body {
        background: #f8f9fa;
    }

    .bg-glass {
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(6px);
    }

    .icon-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: #667eea;
        color: #fff;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 1.3rem;
        margin: auto;
    }

    .kpi-card {
        border-radius: 1rem;
        padding: 1rem;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: .9rem;
    }

        .kpi-card i {
            font-size: 1.8rem;
            opacity: 0.5;
        }

    .category-tile {
        transition: transform .15s ease, box-shadow .15s ease;
    }

        .category-tile:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        }
</style>
