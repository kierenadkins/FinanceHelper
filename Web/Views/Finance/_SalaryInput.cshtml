@model FinanceHelper.Web.Models.Finance.SalaryInputModel

<div class="row justify-content-center align-items-center" style="min-height:65vh">
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm rounded-3 p-4 text-center bg-glass">
            <div class="icon-circle mb-3 mx-auto">
                <i class="bi bi-currency-pound"></i>
            </div>

            <h4 class="fw-bold mb-1">
                @(Model.IsEdit ? "Edit Salary" : "Welcome")
            </h4>

            <p class="text-muted mb-3">
                @(Model.IsEdit
                    ? "Update your salary and recalculate your finances."
                    : "Add your salary to start tracking your finances.")
            </p>

            <form asp-action="SalaryForm" method="get">
                <input asp-for="SalaryId" type="hidden" />
                <input asp-for="IsEdit" type="hidden" />
                <input asp-for="GrossSalary"
                       type="number"
                       step="0.01"
                       class="form-control"
                       placeholder="Annual salary"
                       required />

                <button class="btn btn-primary w-100 rounded-pill py-1">
                    @(Model.IsEdit ? "Update Salary" : "Get Started")
                </button>
            </form>
        </div>
    </div>
</div>